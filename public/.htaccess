# Apache / LiteSpeed config for the static export on Hostinger.
# Each route is exported as <route>/index.html (trailingSlash: true), so a
# direct hit on /pricing resolves to /pricing/index.html.

# Serve index.html for any directory request (fixes 403 "Forbidden" when a
# folder is requested and directory listing is disabled).
DirectoryIndex index.html

# Don't expose directory listings.
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request maps to an existing file, serve it as-is.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # For an existing directory, serve its index.html.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^(.*)$ $1/index.html [L]

  # /pricing -> /pricing/index.html when the .html exists (covers hosts that
  # don't add the trailing slash automatically).
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+?)/?$ $1/index.html [L]
</IfModule>

# Use Next's exported 404 page for missing routes.
ErrorDocument 404 /404.html
